{
  "name": "lumyra",
  "version": "1.0.0",
  "description": "easy use whatsapp bot using baileys",
  "main": "index.js",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "db:push": "prisma db push",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:studio": "prisma studio",
    "lint": "biome check  --write",
    "lint:fix": "biome check  --write --unsafe",
    "format": "biome format --write",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "lumyra",
    "lumyra bot",
    "bot",
    "whatsapp",
    "baileys",
    "whatsapp bot"
  ],
  "author": "Kairuuya",
  "license": "MIT",
  "devDependencies": {
    "@biomejs/biome": "2.4.16",
    "@types/node": "^25.9.2",
    "@types/pg": "8.20.0",
    "@types/qrcode-terminal": "^0.12.2",
    "prisma": "^7.8.0",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  },
  "dependencies": {
    "@hapi/boom": "^10.0.1",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "7.8.0",
    "@whiskeysockets/baileys": "7.0.0-rc13",
    "awesome-phonenumber": "^7.8.0",
    "axios": "^1.17.0",
    "chokidar": "^5.0.0",
    "croner": "^10.0.1",
    "dayjs": "^1.11.21",
    "dotenv": "^17.4.2",
    "esbuild": "^0.28.0",
    "eventemitter3": "^5.0.4",
    "file-type": "^22.0.1",
    "ioredis": "^5.11.1",
    "link-preview-js": "^3.0.0",
    "pg": "^8.21.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "qrcode-terminal": "^0.12.0",
    "zod": "^4.4.3"
  }
}
