generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  FREE
  PREMIUM
}

enum GroupRole {
  MEMBER
  ADMIN
  SUPERADMIN
}

model BaileysAuth {
  sessionId String  @id
  session   String?

  @@map("baileys_auth")
}

model User {
  id           String             @id @default(uuid())
  pn           String?            @unique
  lid          String?            @unique
  pushName     String
  language     String             @default("id")
  role         UserRole           @default(FREE)
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
  participants GroupParticipant[]

  @@index([pn])
  @@index([lid])
  @@map("users")
}

model Group {
  id        String   @id
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  // settings     GroupSetting
  metadata     GroupMetadata?
  participants GroupParticipant[]

  @@map("groups")
}

/// Stores the WhatsApp group metadata (1:1 with Group)
model GroupMetadata {
  id                  String  @id
  addressingMode      String?
  subject             String
  subjectOwner        String?
  subjectOwnerPn      String?
  subjectTime         Int?
  size                Int     @default(0)
  creation            Int?
  owner               String  @default("")
  ownerPn             String?
  ownerCountryCode    String?
  desc                String?
  descId              String?
  descOwner           String?
  descOwnerPn         String?
  descTime            Int?
  restrict            Boolean @default(false)
  announce            Boolean @default(false)
  isCommunity         Boolean @default(false)
  isCommunityAnnounce Boolean @default(false)
  joinApprovalMode    Boolean @default(false)
  memberAddMode       Boolean @default(false)

  // Relations
  group Group @relation(fields: [id], references: [id], onDelete: Cascade)

  @@map("group_metadata")
}

/// Individual participant entries within a group
model GroupParticipant {
  groupid   String
  userId    String
  role      GroupRole @default(MEMBER)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  // Relations
  group     Group     @relation(fields: [groupid], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([groupid, userId])
  @@index([userId])
  @@map("group_participants")
}

model LidMapping {
  lid String @id
  pn  String @unique

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  @@map("lid_mappings")
}
